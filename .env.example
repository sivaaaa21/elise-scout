# ---------------------------------------------------------------------------
# EliseAI Lead Enricher — environment variables
# Copy this file to `.env` and fill in the keys you have. The tool will run
# with whatever keys are available and gracefully skip the rest.
# ---------------------------------------------------------------------------

# US Census API (free): https://api.census.gov/data/key_signup.html
# Technically optional for low volume, but strongly recommended.
CENSUS_API_KEY=

# NewsAPI (free tier, 100 req/day): https://newsapi.org/register
NEWSAPI_KEY=

# OpenWeather (free tier): https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ---------------------------------------------------------------------------
# Optional: LLM provider for richer outreach email copy.
# Leave EMAIL_LLM_PROVIDER blank to use the deterministic template generator.
# ---------------------------------------------------------------------------
# One of: "openai", "anthropic", or blank
EMAIL_LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Optional: Google Sheets adapter
# Path to a service-account JSON key with access to the target sheet.
# ---------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_INPUT_TAB=Leads
GOOGLE_SHEETS_OUTPUT_TAB=Enriched
